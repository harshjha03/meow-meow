# --- Meow Meow environment ---
# Copy this file to `.env` and fill in your values.
# The app works FULLY offline with localStorage even if these are blank;
# they only enable optional cloud sync (Supabase) and Google Calendar.

# Supabase project (Dashboard > Project Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth client ID (the PUBLIC client_id only — NOT the client_secret).
# The client_secret goes into Supabase Dashboard > Authentication > Providers > Google.
VITE_GOOGLE_CLIENT_ID=
